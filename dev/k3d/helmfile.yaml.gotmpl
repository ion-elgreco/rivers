# Declarative deploy for the k3d dev cluster.
#
# Usage: helmfile sync (run from this directory)
# Driven by dev/k3d/setup.sh which creates the cluster + local registry,
# pushes images, then sync's. The operator runs with
# allowInsecureRegistry=true so it can resolve digests directly from the
# HTTP-only k3d registry — no manual digest-pinning needed on the CRs.

kubeContext: k3d-{{ env "RIVERS_K3D_CLUSTER" | default "rivers-test" }}

helmDefaults:
  wait: true
  # Tight fast-fail default for local dev iteration (the rivers chart's
  # `wait-for-surreal` init container does the real readiness gating). CI sets
  # RIVERS_HELMFILE_TIMEOUT to a real value so `sync` waits for the operator +
  # storage to be ready and the deploy is deterministic.
  timeout: {{ env "RIVERS_HELMFILE_TIMEOUT" | default "15" }}
  createNamespace: true

# Pre-register repos so helmfile's automatic `helm dep build` can resolve
# subcharts (rivers depends on the upstream surrealdb chart).
repositories:
  - name: surrealdb
    url: https://helm.surrealdb.com

releases:
  # Cluster-scoped CRDs first; the rivers chart's templates reference them.
  - name: rivers-crds
    namespace: rivers
    chart: ../../deploy/helm/rivers-crds

  # Operator + UI + SurrealDB (subchart). Depends on CRDs.
  - name: rivers
    namespace: rivers
    chart: ../../deploy/helm/rivers
    needs:
      - rivers/rivers-crds
    values:
      - operator:
          # Use the locally-built image (k3d image import), not the ghcr
          # default the chart points to for releases.
          image: rivers-operator:latest
          allowInsecureRegistry: true
        ui:
          # CI (RIVERS_K8S_SKIP_UI=1) never builds/imports the UI image, so
          # don't deploy it either — the integration suite doesn't touch it.
          enabled: {{ if eq (env "RIVERS_K8S_SKIP_UI") "1" }}false{{ else }}true{{ end }}
          image: rivers-ui:latest

  # Dev-cluster scaffolding: MinIO + example CodeLocation CRs.
  - name: rivers-dev
    namespace: rivers
    chart: ./charts/rivers-dev
    needs:
      - rivers/rivers
    values:
      - codeLocations:
          - name: {{ env "RIVERS_K8S_TEST_CODE_LOCATION" | default "k8s-test-pipeline" }}
            image: k3d-rivers-registry:5000/rivers-code-location
            module: k8s_test_pipeline.pipeline
{{- if ne (env "RIVERS_K8S_SKIP_DEMO") "1" }}
          - name: {{ env "RIVERS_K8S_DEMO_CODE_LOCATION" | default "demo" }}
            image: k3d-rivers-registry:5000/rivers-demo
            module: demo_project.pipeline
{{- end }}
